#!/usr/bin/env php
<?php

declare(strict_types=1);

namespace AiMessDetector;

use AiMessDetector\Infrastructure\Console\Application;
use AiMessDetector\Infrastructure\Console\Command\CheckCommand;
use AiMessDetector\Infrastructure\Console\Command\BaselineCleanupCommand;
use AiMessDetector\Infrastructure\Console\Command\GraphExportCommand;
use AiMessDetector\Infrastructure\Console\Command\HookInstallCommand;
use AiMessDetector\Infrastructure\Console\Command\HookStatusCommand;
use AiMessDetector\Infrastructure\Console\Command\HookUninstallCommand;
use AiMessDetector\Infrastructure\Console\Command\RulesCommand;
use AiMessDetector\Infrastructure\DependencyInjection\ContainerFactory;

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',           // Local development
    __DIR__ . '/../../../autoload.php',             // Installed as dependency
];

$autoloaderFound = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(STDERR, "Error: Could not find autoloader. Run 'composer install'.\n");
    exit(1);
}

// Increase memory limit for large projects if current limit is below 512M.
// Users can override with: php -d memory_limit=1G bin/aimd check ...
$currentLimit = ini_get('memory_limit');
if ($currentLimit !== '-1') {
    $currentBytes = (int) $currentLimit;
    $suffix = strtolower(substr($currentLimit, -1));
    if ($suffix === 'g') {
        $currentBytes = (int) $currentLimit * 1024 * 1024 * 1024;
    } elseif ($suffix === 'm') {
        $currentBytes = (int) $currentLimit * 1024 * 1024;
    } elseif ($suffix === 'k') {
        $currentBytes = (int) $currentLimit * 1024;
    }

    if ($currentBytes < 512 * 1024 * 1024) {
        ini_set('memory_limit', '512M');
    }
}

// Create single container with default configuration
// Runtime configuration (CLI options, config file) will be applied
// through ConfigurationProvider and RuleOptionsFactory before analysis
$containerFactory = new ContainerFactory();
$container = $containerFactory->create();

// Get commands from container (all dependencies injected)
/** @var CheckCommand $analyzeCommand */
$analyzeCommand = $container->get(CheckCommand::class);
/** @var BaselineCleanupCommand $baselineCleanupCommand */
$baselineCleanupCommand = $container->get(BaselineCleanupCommand::class);
/** @var GraphExportCommand $graphExportCommand */
$graphExportCommand = $container->get(GraphExportCommand::class);
/** @var HookInstallCommand $hookInstallCommand */
$hookInstallCommand = $container->get(HookInstallCommand::class);
/** @var HookUninstallCommand $hookUninstallCommand */
$hookUninstallCommand = $container->get(HookUninstallCommand::class);
/** @var HookStatusCommand $hookStatusCommand */
$hookStatusCommand = $container->get(HookStatusCommand::class);
/** @var RulesCommand $rulesCommand */
$rulesCommand = $container->get(RulesCommand::class);

// Create and run application
$application = new Application();
$application->addCommands([
    $analyzeCommand,
    $baselineCleanupCommand,
    $graphExportCommand,
    $hookInstallCommand,
    $hookUninstallCommand,
    $hookStatusCommand,
    $rulesCommand,
]);
// No default command - show help/list when run without arguments

exit($application->run());
