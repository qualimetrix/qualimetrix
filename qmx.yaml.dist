# Qualimetrix - Default Configuration
# Copy this file to qmx.yaml and customize as needed.

# General settings
cache:
  dir: .qmx-cache
  enabled: true

format: text  # text, json, checkstyle

# PHP memory limit (default: php.ini value)
# memory_limit: 512M  # e.g., 512M, 1G, -1 (unlimited)

# Namespace detection
namespace:
  strategy: chain  # psr4, tokenizer, chain
  # composer_json: composer.json  # Path for PSR-4 detection

# Aggregation settings
aggregation:
  prefixes: []  # e.g., ['App\Domain', 'App\Infrastructure']
  # auto_depth: 2

# Rules configuration
# Rule names use group.rule-name format (e.g., complexity.cyclomatic)
rules:
  complexity.cyclomatic:
    method:
      warning: 10
      error: 20
    class:
      max_warning: 30   # Maximum CCN among class methods
      max_error: 50

  size.method-count:
    warning: 20   # Methods per class
    error: 30

  size.class-count:
    warning: 15   # Classes per namespace
    error: 25

# Disable specific rules or violation codes
# Uses prefix matching: 'complexity' disables all complexity.* rules
# disabled_rules:
#   - complexity.cyclomatic.class  # Disable class-level cyclomatic check
#   - size                         # Disable all size checks
#   - code-smell                   # Disable all code-smell rules

# Run only specific rules (prefix matching applies)
# only_rules:
#   - complexity           # Only run all complexity rules
#   - size.method-count    # Only run method count check
